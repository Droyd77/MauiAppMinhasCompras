<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="MauiAppMinhasCompras.Views.ListaProduto"
             Title="Minhas compras"
             Shell.NavBarIsVisible="False"
             BackgroundColor="LightGreen">

    <ContentPage.ToolbarItems>
        <ToolbarItem Text="Somar"     Clicked="ToolbarItem_Clicked_1"/>
        <ToolbarItem Text="Relatório" Clicked="ToolbarItem_Clicked_Relatorio"/>
        <ToolbarItem Text="Adicionar" Clicked="ToolbarItem_Clicked"/>
    </ContentPage.ToolbarItems>

    <ContentPage.Resources>
        <ResourceDictionary>
            <Style TargetType="Label">
                <Setter Property="VerticalTextAlignment" Value="Center"/>
            </Style>
        </ResourceDictionary>
    </ContentPage.Resources>

    <!-- Grid com 4 linhas: título, busca, filtro, lista (lista ocupa o espaço restante com *) -->
    <Grid Padding="20" RowSpacing="10"
          RowDefinitions="Auto,Auto,Auto,*" >

        <!-- Linha 0: Título -->
        <Label Grid.Row="0"
               Text="Lista de Produtos"
               FontSize="40"
               HorizontalOptions="Center"
               FontFamily="BAUHS93"
               TextColor="Black"/>

        <!-- Linha 1: Busca -->
        <SearchBar Grid.Row="1"
                   x:Name="txt_search"
                   Margin="-15,0,0,0"
                   Placeholder="Busca de Produtos"
                   TextChanged="txt_search_TextChanged" BackgroundColor="White" />

        <!-- Linha 2: Filtro por categoria (Desafio 1) -->
        <Grid Grid.Row="2" ColumnDefinitions="Auto,*" ColumnSpacing="8">
            <Label Grid.Column="0" Text="Categoria:" FontAttributes="Bold" VerticalOptions="Center"/>
            <Picker Grid.Column="1"
                    x:Name="pkr_filtro_categoria"
                    Title="Todas"
                    HorizontalOptions="Fill"
                    SelectedIndexChanged="pkr_filtro_categoria_SelectedIndexChanged" BackgroundColor="White"/>
        </Grid>

        <!-- Linha 3: Frame + ListView ocupa todo o espaço restante -->
        <Frame Grid.Row="3" Padding="0" Margin="0,5,0,0">
            <ListView x:Name="lst_produtos"
                      IsPullToRefreshEnabled="True"
                      Refreshing="lst_produtos_Refreshing"
                      ItemSelected="lst_produtos_ItemSelected">

                <ListView.Header>
                    <Grid ColumnDefinitions="30,90,75,50,75,80"
                          BackgroundColor="{StaticResource Gray100}">
                        <Label Grid.Column="0" Text="Id"        Padding="5" FontAttributes="Bold"/>
                        <Label Grid.Column="1" Text="Descricao"             FontAttributes="Bold"/>
                        <Label Grid.Column="2" Text="Categoria"             FontAttributes="Bold"/>
                        <Label Grid.Column="3" Text="Qtd"                   FontAttributes="Bold"/>
                        <Label Grid.Column="4" Text="Preco"                 FontAttributes="Bold"/>
                        <Label Grid.Column="5" Text="Total"                 FontAttributes="Bold"/>
                    </Grid>
                </ListView.Header>

                <ListView.ItemTemplate>
                    <DataTemplate>
                        <ViewCell>
                            <ViewCell.ContextActions>
                                <MenuItem Text="Remover" Clicked="MenuItem_Clicked"/>
                            </ViewCell.ContextActions>
                            <Grid ColumnDefinitions="30,90,75,50,75,80">
                                <Label Grid.Column="0" Text="{Binding Id}"/>
                                <Label Grid.Column="1" Text="{Binding Descricao}"/>
                                <Label Grid.Column="2" Text="{Binding Categoria}"/>
                                <Label Grid.Column="3" Text="{Binding Quantidade}"/>
                                <Label Grid.Column="4" Text="{Binding Preco, StringFormat='R$ {0:F2}'}"/>
                                <Label Grid.Column="5" Text="{Binding Total, StringFormat='R$ {0:F2}'}"/>
                            </Grid>
                        </ViewCell>
                    </DataTemplate>
                </ListView.ItemTemplate>

            </ListView>
        </Frame>

    </Grid>
</ContentPage>
