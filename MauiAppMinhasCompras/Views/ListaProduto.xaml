<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="MauiAppMinhasCompras.Views.ListaProduto"
             Title="Minhas compras"
             Shell.NavBarIsVisible="False"
               BackgroundColor="LightGreen">

    <ContentPage.ToolbarItems>
        <ToolbarItem Text="Somar" Clicked="ToolbarItem_Clicked_1"/>
        <ToolbarItem Text="Adicionar" Clicked="ToolbarItem_Clicked"/>

    </ContentPage.ToolbarItems>


    <StackLayout Padding="20" Spacing="15" >
        <Label Text="Lista de Produtos" 
       FontSize="40"                    
       HorizontalOptions="Center" 
       FontFamily="BAUHS93"  TextColor="Black"
       />

        <ContentPage.Resources>
            <ResourceDictionary>
                <Style TargetType="Label">
                    <Setter Property="VerticalTextAlignment" Value="Center"/>
                </Style>
            </ResourceDictionary>
        </ContentPage.Resources>

        <SearchBar x:Name="txt_search" 
                   Margin="-15, 0, 0, 0"
                   Placeholder="Busca de Produtos" 
                   TextChanged="txt_search_TextChanged"/>
        
        <Frame Padding="0" Margin="10" VerticalOptions="FillAndExpand">  
        <ListView x:Name="lst_produtos"
                  IsPullToRefreshEnabled="True"
                  Refreshing="lst_produtos_Refreshing"
                  ItemSelected="lst_produtos_ItemSelected">
            
            <ListView.Header>
                <Grid ColumnDefinitions="30,100,80,50,90" 
                      BackgroundColor="{StaticResource Gray100}">
                        <Label Grid.Column="0" Text="Id" Padding="5"  FontAttributes="Bold"/>
                        <Label Grid.Column="1" Text="Descricao"   FontAttributes="Bold"/>
                        <Label Grid.Column="2" Text="Preco"  FontAttributes="Bold" />
                        <Label Grid.Column="3" Text="Quantidade"  FontAttributes="Bold" />
                    <Label Grid.Column="4" Text="Total" FontAttributes="Bold" />                                      
                </Grid>                
            </ListView.Header>

            <ListView.ItemTemplate>
                <DataTemplate>
                    <ViewCell>
                        <ViewCell.ContextActions>
                            <MenuItem Text="Remover" Clicked="MenuItem_Clicked"/>
                        </ViewCell.ContextActions>

                            <Grid ColumnDefinitions="30,100,80,50,90">
                            <Label Grid.Column="0" Text="{Binding Id}" />
                            <Label Grid.Column="1" Text="{Binding Descricao}" />
                            <Label Grid.Column="2" Text="{Binding Preco, StringFormat='R$ {0:F2}'}" />
                            <Label Grid.Column="3" Text="{Binding Quantidade}" />
                            <Label Grid.Column="4" Text="{Binding Total, StringFormat='R$ {0:F2}'}" />
                        </Grid>

                    </ViewCell>
                    
                </DataTemplate>
            </ListView.ItemTemplate>
        </ListView>
        </Frame>
    </StackLayout>
</ContentPage>