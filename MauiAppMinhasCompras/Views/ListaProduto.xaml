<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="MauiAppMinhasCompras.Views.ListaProduto"
             Title="ListaProduto"
             Shell.NavBarIsVisible="False"
               BackgroundColor="LightGreen">

    <VerticalStackLayout Padding="20" Spacing="15" >
        <Label Text="Lista de Produtos" 
       FontSize="40"                    
       HorizontalOptions="Center" 
       FontFamily="BAUHS93"  TextColor="Black"
       />
        <!-- Nome -->
        <Label Text="Nome da Lista" FontAttributes="Bold"  TextColor="White" />
        <Entry Placeholder="Digite o nome" PlaceholderColor="Black" Text="{Binding NomeEvento}" BackgroundColor="White"  />

        <Button Text="Criar Lista"
                    BackgroundColor="Black"  
                TextColor="White"
                CornerRadius="15"
                FontSize="18"
                Padding="12"
                Clicked="Button_Clicked_2"
                HorizontalOptions="Center"
            
            />



    </VerticalStackLayout>
</ContentPage>